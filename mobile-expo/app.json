{
  "expo": {
    "name": "Photobookers",
    "slug": "photobookers",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#fbfaf7"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.photobookers.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#fbfaf7"
      },
      "package": "com.photobookers.app"
    },
    "plugins": [
      "expo-secure-store",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Photobookers to access your photos to set a profile picture."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "c999a628-9011-4698-b76c-d3ce15eabfce"
      }
    },
    "owner": "eannadefreine"
  }
}
