# Copy to .env for local development:
#   cp .env.example .env
#
# --- EAS / App Store (Step 5) ---
# 1. cd mobile-expo && npm install
# 2. npm run eas:login     (opens browser — use Google sign-in)
# 3. npm run eas -- whoami  (should show your Expo username)
# 4. npm run eas:init
#    (links project on expo.dev and writes extra.eas.projectId to app config)
# 3. Set Supabase secrets for cloud builds (from repo root .env.production):
#    eas secret:create --scope project --name EXPO_PUBLIC_SUPABASE_URL --value "https://YOUR_PROJECT.supabase.co"
#    eas secret:create --scope project --name EXPO_PUBLIC_SUPABASE_ANON_KEY --value "YOUR_ANON_KEY"
#    (EXPO_PUBLIC_SERVER_URL is set in eas.json → https://photobookers.com)
# 4. npm run build:ios          → production build for TestFlight
# 5. npm run submit:ios         → upload to App Store Connect (after build)
#
# Use the same Supabase project as production web (.env.production in repo root).
#
# iOS App Transport Security (app.config.js):
# - http:// URLs (local dev): allows LAN/localhost HTTP via NSAllowsLocalNetworking
# - https:// URLs (production / EAS): strict HTTPS only — no NSAllowsArbitraryLoads

# Hyperview server (no trailing slash)
# Local: your machine IP + dev port, or http://localhost:3000
EXPO_PUBLIC_SERVER_URL=http://localhost:3000

# Production example (for EAS builds — do not commit real keys):
# EXPO_PUBLIC_SERVER_URL=https://photobookers.com

EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
