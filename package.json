{
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:fsr": "hono-fsr -r ./src/fs-routes -o ./src/fs-routes.manifest.ts -w",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:fsr\"",
    "dev:all:production": "DOTENV_CONFIG_PATH=.env.production concurrently \"node -r dotenv/config ./node_modules/vite/bin/vite.js\" \"node -r dotenv/config ./node_modules/.bin/hono-fsr -r ./src/fs-routes -o ./src/fs-routes.manifest.ts -w\"",
    "build": "hono-fsr -r ./src/fs-routes -o ./src/fs-routes.manifest.ts && vite build && node scripts/build-server.mjs",
    "build:deploy": "npm run build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/fs-routes/(app)\" \"src/fs-routes/hyperview\"",
    "start": "NODE_ENV=production node dist/server/server.js",
    "start:local": "NODE_ENV=production DOTENV_CONFIG_PATH=.env.production node -r dotenv/config dist/server/server.js",
    "start:tsx": "NODE_ENV=production node --import tsx src/server.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:production": "DOTENV_CONFIG_PATH=.env.production node -r dotenv/config ./node_modules/.bin/drizzle-kit migrate",
    "db:verify-column": "npx tsx scripts/db-verify-column.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "export-social-week": "ENV=production npx tsx scripts/export-social-week.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install chromium",
    "postinstall": "patch-package && node scripts/render-postinstall.mjs",
    "fallow": "fallow",
    "fallow:audit": "fallow audit --base main",
    "fallow:dead-code": "fallow dead-code"
  },
  "dependencies": {
    "@alpinejs/collapse": "^3.15.11",
    "@alpinejs/focus": "^3.15.3",
    "@alpinejs/intersect": "^3.15.8",
    "@alpinejs/morph": "^3.15.8",
    "@alpinejs/persist": "^3.15.9",
    "@alpinejs/resize": "^3.15.10",
    "@fontsource/caveat": "^5.2.8",
    "@fontsource/fraunces": "^5.2.9",
    "@fontsource/instrument-sans": "^5.2.8",
    "@google-analytics/data": "^6.1.0",
    "@hono/node-server": "^2.0.6",
    "@hono/session": "^0.2.0",
    "@imacrayon/alpine-ajax": "^0.12.6",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.10",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.78.0",
    "@tailwindcss/vite": "^4.1.18",
    "alpinejs": "^3.15.2",
    "browser-image-compression": "^2.0.2",
    "cheerio": "^1.1.0",
    "clsx": "^2.1.1",
    "csv": "^6.4.1",
    "dotenv": "^17.2.3",
    "drizzle-kit": "^0.31.7",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.27",
    "hono-fsr": "^1.2.1",
    "juice": "^11.1.1",
    "lru-cache": "^11.3.5",
    "mjml": "^4.18.0",
    "mjml-react": "^2.0.8",
    "nanoid": "^5.1.6",
    "patch-package": "^8.0.1",
    "postgres": "^3.4.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@hono/vite-dev-server": "^0.23.0",
    "@playwright/test": "^1.61.1",
    "@types/alpinejs": "^3.13.11",
    "@types/node": "^20.11.17",
    "@types/react": "^19.2.15",
    "@types/sanitize-html": "^2.16.0",
    "concurrently": "^9.2.1",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "fallow": "^2.104.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^6.4.1",
    "vitest": "^3.2.4"
  }
}
